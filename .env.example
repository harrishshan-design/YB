# For local Postgres:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ngo_system?schema=public"
#
# For the HH CHARITY Supabase project (db.gbxgqmsnuczblclrplyw.supabase.co):
# get both connection strings from Supabase Dashboard -> Project Settings -> Database.
# DATABASE_URL is the pooled "Transaction" connection (port 6543, ?pgbouncer=true) the app uses at runtime.
# DIRECT_URL is the non-pooled "Session"/direct connection (port 5432) Prisma needs for migrations.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ngo_system?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/ngo_system?schema=public"
PORT=4000
NEXT_PUBLIC_API_URL="http://localhost:4000"
WEB_ORIGIN="http://localhost:3000"
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace-with-a-long-random-secret"
